rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. USUARIOS: Solo el dueño puede leer/escribir su propio perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. VIAJES: Solo el usuario que creó el viaje puede verlo o editarlo
    match /trips/{tripId} {
      allow read, write: if request.auth != null && request.auth.uid == (resource == null ? request.auth.uid : resource.data.userId);
    }
    
    // 3. VUELOS Y AGENTE: El usuario autenticado puede leer y el agente (backend) puede actualizar
    match /flights/{flightId} {
      allow read, write: if request.auth != null;
    }
    
    match /agent_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Prohibir todo lo demás por defecto (Seguridad Máxima)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
